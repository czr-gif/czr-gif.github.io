@article{Chen_2025_automatica,
  title   = {Non-singular cooperative guiding vector field under a homotopy equivalence transformation},
  volume  = {171},
  doi     = {10.1016/j.automatica.2024.111962},
  journal = {Automatica},
  author  = {Chen, Zirui and Zuo, Zongyu},
  abstract = {The present article introduces the concept of a non-singular cooperative guiding vector field under a homotopy equivalence transformation. Initially, an innovative non-singular guiding vector field is derived, which is capable of guiding the controlled robot to follow a path in a moving frame. Furthermore, the properties of homotopy equivalence transformation are explored to establish the existence of the aforementioned vector field. Subsequently, a cooperative vector field, based on an extensive parameter consensus protocol, is introduced, including an in-depth analysis of the impact of vector field parameters. Then, the practical implementation of this innovative vector field is demonstrated through its application to cooperative path following in both 2-D and 3-D scenarios, showcasing its effectiveness. Finally, for a non-holonomic robot at constant speed, a moving path following control law based on the guiding vector field is presented, along with a discussion on speed constraint.},
  preview={chen_auto_2025.jpg},
  selected = {true},
  description={This paper proposes a non-singular cooperative guiding vector field based on homotopy equivalence transformation for cooperative path following. The method is validated in both 2-D and 3-D scenarios, and a control law for constant-speed non-holonomic robots is also developed with consideration of speed constraints.},
  keywords={Path following, Vector field, Homotopy equivalence transformation, Singularity, Cooperative control},
  year    = {2025},
  month   = jan,
  pages   = {111962},
}

@article{Chen_2024_jas,
  title   = {A Novel Prescribed-Performance Path-Following Problem for Non-Holonomic Vehicles},
  volume  = {11},
  doi     = {10.1109/jas.2024.124311},
  number  = {6},
  journal = {IEEE/CAA Journal of Automatica Sinica},
  author  = {Chen, Zirui and Tang, Jingchuan and Zuo, Zongyu},
  year    = {2024},
  month   = jun,
  pages   = {1476--1484},
  abstract = {The issue of achieving prescribed-performance path following in robotics is addressed in this paper, where the aim is to ensure that a desired path within a specified region is accurately converged to by the controlled vehicle. In this context, a novel form of the prescribed performance guiding vector field is introduced, accompanied by a prescribed-time sliding mode control approach. Furthermore, the interdependence among the prescribed parameters is discussed. To validate the effectiveness of the proposed method, numerical simulations are presented to demonstrate the efficacy of the approach.},
  preview={chen_jas_2024.gif},
  description={This paper addresses the challenge of prescribed-performance path following for non-holonomic vehicles, introducing a novel guiding vector field and a sliding mode control approach.},
  keywords={Path following, Vector field, Homotopy equivalence transformation, Singularity},
}

@article{Chen_2025_tmech,
  title   = {Discrete Data-Based Frequency-Domain Closed Planar Path Following Method},
  doi     = {10.1109/tmech.2025.3566540},
  journal = {IEEE/ASME Transactions on Mechatronics},
  author  = {Chen, Zirui and Zuo, Zongyu and Wang, Gang and Li, Peng and Liu, Yunhui},
  year    = {2025},
  month   = jan,
  pages   = {1--12},
  abstract = {This article presents a frequency-domain method for following paths that cannot be expressed analytically. First, the path is described using discrete path points. The proposed algorithm utilizes the fast Fourier transform (FFT) to process this data, enabling the construction of a nonsingular guiding vector field. This vector field serves as a reference direction for the controlled robot, allowing for adjustments at different levels of precision. In addition, the frequency-domain nature of the vector field reduces computational complexity and effectively suppresses noise. This approach also facilitates the formation of specific patterns in group systems. The efficacy of the proposed method is demonstrated through numerical simulations and experiments with the TurtleBot3 and Crazyflie 2.1 quadrotors. Finally, a comparative study is conducted to highlight the advantages, robustness, and parameter sensitivity of the proposed algorithm.},
  preview={chen_Tmech_2025.png},
  selected = {true},
  description={This article introduces a frequency-domain method for path following using discrete data points and fast Fourier transform (FFT) techniques.},
  keywords={Frequency-domain methods, Path following, Discrete data, Fast Fourier Transform, Robotics},
}

@inproceedings{Chen_2026_icra,
  title     = {Guiding Vector Field Generation via Score-based Diffusion Model},
  booktitle = {2026 IEEE International Conference on Robotics and Automation (ICRA)},
  author    = {Chen, Zirui and Guo, Shiliang and Zhao, Shiyu},
  year      = {2026},
  month     = feb,
  address   = {Vienna, Austria},
  note      = {Accepted},
  abstract = {Guiding Vector Fields (GVFs) are a powerful tool for robotic path following. However, classical methods assume smooth, ordered curves and fail when paths are unordered, multi-branch, or generated by probabilistic models. We propose a unified framework, termed the Score-Induced Guiding Vector Field (SGVF), which leverages score-based generative modeling to construct vector fields directly from data distributions. SGVF learns tangent fields from point clouds with unit-norm, orthogonality, and directional-consistency losses, ensuring geometric fidelity and control feasibility. This approach removes the reliance on ad-hoc path segmentation and enables guidance along complex topologies such as branching and pseudo-manifolds. The study establishes a correspondence between score vanishing in diffusion models and GVF singularities and highlights representational capacity near sharp path curvatures. Experiments on robotic navigation in planar environments demonstrate that SGVF achieves reliable path following in scenarios where classical GVFs fail, underscoring its potential as a bridge between generative modeling and geometric control.},
  preview={chen_icra_2026.png},
  selected = {true},
  description={This paper presents a novel approach to generating guiding vector fields for robotic path following using score-based diffusion models. The proposed method addresses the limitations of classical GVFs by enabling the construction of vector fields directly from data distributions, allowing for more complex and varied path geometries.},
  keywords={Guiding Vector Fields, Score-based Diffusion Models, Robotic Path Following},
  code ={https://github.com/czr-gif/Guiding-Vector-Field-Generation-via-Score-based-Diffusion-Model}, 
}

@inproceedings{yue_2026_icme,
  title     = {Completing the Response Space: Unifying Rejection and Multi-Interval Video Grounding via Cardinality-Rectified GRPO},
  booktitle = {2026 IEEE International Conference on Multimedia and Expo (ICME)},
  author    = {Feng Yue, et al. and Zirui Chen},
  year      = {2026},
  note      = {Accepted},
  abstract = {Existing Temporal Video Grounding (TVG) methods fail to reject irrelevant queries or distinguish disjoint events due to a forced single-interval assumption. We unify these failures under the perspective of Cardinality Generalization, theoretically demonstrating that standard RL objectives suffer from a Gambling Bias in zero-instance scenarios (incentivizing guessing) and a Unimodal Bias in multi-instance scenarios (favoring merging). To rectify this, we propose CaR-GRPO (Cardinality-Rectified Group Relative Policy Optimization). Our framework introduces an implicit calibration mechanism via negative sampling to establish a robust rejection boundary, alongside novel Cardinality and Endpoint Distance objectives to enforce structural precision. Extensive experiments show that CaR-GRPO effectively eliminates the identified biases, achieving state-of-the-art performance in both rejection capability and multi-interval retrieval.},
  preview={yue_icme_2026.png},
  selected = {true},
  description={This paper addresses the limitations of existing Temporal Video Grounding methods in handling irrelevant queries and disjoint events, framing both issues as a problem of cardinality generalization. To overcome the gambling and unimodal biases in standard RL objectives, it proposes CaR-GRPO, which improves rejection capability and multi-interval retrieval through implicit calibration, cardinality-aware optimization, and endpoint distance objectives. Experiments demonstrate that the method effectively removes these biases and achieves state-of-the-art performance.},
  keywords={Temporal Video Grounding, Cardinality Generalization, Reinforcement Learning, CaR-GRPO},
}
